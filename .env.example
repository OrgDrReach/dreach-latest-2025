# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# API and Backend Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000
BACKEND_URL=http://localhost:4000
API_KEY=your-api-key
NEXT_PUBLIC_WS_URL=ws://localhost:4000  # WebSocket URL for real-time features
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key  # For location services

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/drreach?schema=public"

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880  # 5MB in bytes
ALLOWED_FILE_TYPES=image/*,application/pdf

# Redis Configuration (for caching and real-time features)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Email Configuration (for notifications and verifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@drreach.com

# SMS Gateway (for OTP and Verification)
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=DRREACH
SMS_OTP_TEMPLATE=your-otp-template-id

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Security
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRY=7d
COOKIE_SECRET=your-cookie-secret
ACCESS_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# Feature Flags
ENABLE_VIDEO_CONSULTATION=true
ENABLE_HOME_VISITS=true
ENABLE_INTEGRATED_CARE=true
ENABLE_ANALYTICS=true
ENABLE_EMERGENCY_SERVICES=true

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes

# Analytics
ANALYTICS_ENABLED=true
GOOGLE_ANALYTICS_ID=your-ga-id

# Environment
NODE_ENV=development